{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "DevBot API Server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["src/core/app.js"],
      "port": 3000
    },
    {
      "name": "DevBot API (Watch Mode)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch", "src/core/app.js"],
      "port": 3000
    },
    {
      "name": "Slack Bot (HTTP)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["src/slack/bot.js"],
      "port": 3001
    },
    {
      "name": "Slack Assistant (Python Socket Mode)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["assistant/app.py"],
      "port": 0
    },
    {
      "name": "Trading Bot (Interactive)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["trading-bot/bot.py"],
      "port": 0
    },
    {
      "name": "Scent of Adelaide (Static Site)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "scent-of-adelaide", "-l", "5000"],
      "port": 5000
    },
    {
      "name": "Workflow Dashboard",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch", "src/core/app.js"],
      "port": 3000,
      "env": {
        "DEVBOT_WORKFLOWS_ENABLED": "true"
      }
    }
  ]
}
