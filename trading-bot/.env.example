# ============================================
# DEVBOT TRADING BOT — Environment Variables
# ============================================
# Copy this file to .env and fill in your keys
# NEVER commit .env to git!

# Coinbase Developer Platform (CDP) API
# Generate at: https://portal.cdp.coinbase.com
CDP_API_KEY_NAME=your-cdp-api-key-name
CDP_API_KEY_PRIVATE_KEY=your-cdp-private-key-here

# Network: "base-mainnet" for real money, "base-sepolia" for testnet
NETWORK_ID=base-sepolia

# Anthropic (Claude) — for AI trading decisions
ANTHROPIC_API_KEY=your-anthropic-api-key

# Trading Configuration
TRADE_AMOUNT_USD=25
MAX_DAILY_TRADES=10
STOP_LOSS_PERCENT=5
TAKE_PROFIT_PERCENT=10
DCA_INTERVAL_HOURS=4
STRATEGY=momentum

# Supported strategies: momentum, dca, mean_reversion, grid, rebalance