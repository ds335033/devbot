{
  "version": 2,
  "name": "dwvbotai-store",
  "builds": [
    {
      "src": "src/core/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "storefront/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/store/(.*)", "dest": "/storefront/$1" },
    { "src": "/store", "dest": "/storefront/index.html" },
    { "src": "/api/(.*)", "dest": "/src/core/app.js" },
    { "src": "/health", "dest": "/src/core/app.js" },
    { "src": "/(.*)", "dest": "/storefront/$1" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
